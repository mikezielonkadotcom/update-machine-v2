# ============================================================================
# Update Machine v2 — Local Development Environment
# ============================================================================
# Copy this file:  cp .env.local.template .env.local
# Then edit values as needed. Works with docker-compose.dev.yml out of the box.
# ============================================================================

# ─── Database (docker-compose postgres) ─────────────────────────────────────
DATABASE_URL=postgres://um_dev:um_dev_password@localhost:5432/update_machine

# ─── R2 Storage → MinIO (local S3-compatible replacement) ───────────────────
# MinIO from docker-compose.dev.yml acts as a drop-in for Cloudflare R2.
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET_NAME=update-machine-releases

# ─── Admin Auth ─────────────────────────────────────────────────────────────
# HMAC signing secret for session cookies and bearer token validation.
# In dev, any random string works. In production, use a strong 64-char secret.
ADMIN_TOKEN=local-dev-hmac-secret-change-in-production

# Bootstrap owner account — only used when no users exist in the database.
# Password "admin" hashed with SHA-256 for initial setup:
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD_HASH=sha256:8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918

# ─── Registration ───────────────────────────────────────────────────────────
# Shared secret for site auto-registration HMAC validation.
# Must match the value in the WordPress um-updater.php plugin.
REGISTRATION_SECRET=local-dev-registration-secret

# ─── Slack (optional — leave blank to disable notifications) ────────────────
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_CHANNEL=C0ANNJ51A87

# ─── Cron (optional — used to protect /api/cron/digest endpoint) ────────────
CRON_SECRET=local-dev-cron-secret

# ─── Public URL ─────────────────────────────────────────────────────────────
# Used for magic link emails. Defaults to request origin if unset.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated origins. In dev mode, defaults to request origin if unset.
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
