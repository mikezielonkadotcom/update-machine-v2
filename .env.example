# Database (Vercel Postgres / Neon)
DATABASE_URL=postgres://user:password@host:5432/dbname

# R2 Storage (S3-compatible)
R2_ENDPOINT=https://accountid.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=update-machine-releases

# Admin Auth
ADMIN_TOKEN=your-hmac-signing-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=sha256-hash-of-initial-password

# Registration
REGISTRATION_SECRET=shared-secret-matching-um-updater

# Slack (optional)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL=C0ANNJ51A87

# Vercel Cron
CRON_SECRET=your-cron-secret

# Public URL (for magic links)
NEXT_PUBLIC_BASE_URL=https://updatemachine.com
